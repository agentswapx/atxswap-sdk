{
  "name": "atxswap-sdk",
  "version": "0.0.6",
  "description": "TypeScript SDK for ATX token on-chain interactions (BSC / PancakeSwap V3) — wallet management, price/balance queries, swaps, concentrated liquidity, and transfers.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README.zh.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "viem": "^2.31.3"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "keywords": [
    "atx",
    "atxswap",
    "bsc",
    "binance-smart-chain",
    "pancakeswap",
    "pancakeswap-v3",
    "defi",
    "viem",
    "wallet",
    "swap",
    "liquidity",
    "sdk",
    "agent"
  ],
  "license": "MIT",
  "author": "agentswapx",
  "homepage": "https://github.com/agentswapx/atxswap-sdk#readme",
  "bugs": {
    "url": "https://github.com/agentswapx/atxswap-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentswapx/atxswap-sdk.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
